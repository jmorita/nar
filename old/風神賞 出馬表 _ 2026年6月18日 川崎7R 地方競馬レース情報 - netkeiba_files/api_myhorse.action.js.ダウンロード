function get_race_movie_data( _ref_pogId, _ref_subname_id, _ary_race_id, arg_kaisai_date, _callback )
{
    var url = '';
    var _data = { pid : 'api_get_race_movie_data' };
    _data.input  = 'UTF-8';
    _data.output = 'json';
    _data.ref_pogId = _ref_pogId;
    _data.ref_subname_id = _ref_subname_id;
    _data.race_id = _ary_race_id;
    _data.arg_kaisai_date = arg_kaisai_date;
    $.ajax( { type     : 'GET',
	    url      : _action_api_url_race_movie_data,
  	    data     : _data,
        headers : {
            'Cache-Control': 'no-cache, no-store, must-revalidate', 'Pragma': 'no-cache','Expires': '0'
        },
        cache: false,
	      dataType : 'json',
          xhrFields: { withCredentials: true },
	      success  : function( json )
              {
                    if(json.status == 'OK'){
                        if(undefined != _callback){
                                _callback( json );
                        }
                    }
              },
	      error  : function(XMLHttpRequest, textStatus, errorThrown)
              {
	              console.log('textStatus='+textStatus);
              }
	    });
    return url;
}

//------------------------------------------------------------
function get_myrace_data( arg_kaisai_date, _callback )
{
    var _data = { pid : 'api_get_my_race' };
    _data.input       = 'UTF-8';
    _data.output      = 'json';
    _data.kaisai_date = arg_kaisai_date;

    $.ajax( { type     : 'GET',
        url      : _action_api_url_myrace_data,
        data     : _data,
        dataType : _data.output,
        headers : {
            'Cache-Control': 'no-cache, no-store, must-revalidate', 'Pragma': 'no-cache','Expires': '0'
        },
        cache: false,
        success  : function( json )
        {
            if (json.status == 'NG') {
                console.log('status:NG reason:'+ json.reason);
            } else {
                if(undefined != _callback){
                    _callback( json );
                }
            }
        },
        error  : function(XMLHttpRequest, textStatus, errorThrown)
        {
            console.log('XMLHttpRequest: %O',XMLHttpRequest);
            console.log('textStatus: %s',textStatus);
        }
    });
} 
