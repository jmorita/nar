function getMyhorseEntryDataV3(_ary_race_id) {
//    console.log('getMyhorseEntryDataV3');
    if (_ary_race_id.length<1) {
        $('#HorseBookmark_Box_v3').empty();
        return;
    }
    var _data = {};
    _data.input    = 'UTF-8';
    _data.output   = 'jsonp';
    _data.race_id  = _ary_race_id;
    $.ajax( { type     : 'POST',
        url      : _action_api_url_myhorse_data,
        data     : _data,
        dataType : _data.output,
        success  : function( elm ){
            if (elm.length>0) {
                $('#HorseBookmark_Box_v3').html(elm);
                $('[id^=n-entry_]').each(function(){
                    var n = $(this).prop('id').replace('n-entry_', '');
                    $('#note_'+n).removeClass('disp_none');
                });
                $('[id^=b-entry_]').each(function(){
                    var n = $(this).prop('id').replace('b-entry_', '');
                    $('#myhorse_'+n).removeClass('disp_none');
                });
            } else {
                $('#HorseBookmark_Box_v3').empty();
            }
        },
        complete : function (){}
    });
}

