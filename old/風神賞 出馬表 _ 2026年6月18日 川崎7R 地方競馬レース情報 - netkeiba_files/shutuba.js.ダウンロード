	//            selectFancy( $(this).attr('class') );
	//    });
        cart_get_itemlist( _shutuba_cart_group, init_checkbox );
    }

    // myhorse entry ?? 
    get_myhorse_entry(_shutuba_race_id, callback_myhorse_show);

});

