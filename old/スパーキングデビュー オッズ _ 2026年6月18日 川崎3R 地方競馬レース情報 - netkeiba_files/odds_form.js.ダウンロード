//
// 数字を□囲みに書き換える
//
function make_rectangle_number(ary_number)
{
    var html_tmp="";
    for (var i = 0; i < ary_number.length; i ++) {
        // html_tmp += '<span class="UmaBan">'+ary_number[i]+'</span>';
        if (i>0) {
            html_tmp += '<span class="BackSlash">/</span>' + ary_number[i];
        } else {
            html_tmp += ary_number[i];
        }
    }
    return html_tmp;
}


