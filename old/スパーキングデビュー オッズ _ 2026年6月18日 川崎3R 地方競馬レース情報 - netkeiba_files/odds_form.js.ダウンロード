function calc_tensu(_kind,_type)
{
    console.log('calc_tensu');

    switch(_type)
    {
    //フォーメーション点数計算
    case 'c1':
        var frm1 = []; //[];
        var frm2 = []; //[];
        var frm3 = []; //[];
        var active_waku = []; //[];
        var i=0;
        
        i=0;
        $("[id^='chk_frm1']").each(function()
    	{
    		var chkbox = $(this);
    		if ( chkbox.prop("checked") == true )
    		{
                frm1[i++]=$(this).val();
    		}
        });
        i=0;
        $("[id^='chk_frm2']").each(function()
    	{
    		var chkbox = $(this);
    		if ( chkbox.prop("checked") == true )
    		{
                frm2[i++]=$(this).val();
    		}
        });
        i=0;
        $("[id^='chk_frm3']").each(function()
    	{
    		var chkbox = $(this);
    		if ( chkbox.prop("checked") == true )
    		{
                frm3[i++]=$(this).val();
    		}
        });

        var ten_count = [];
        var kumi = [];

        switch(_kind)
        {
        case 'b4':
        case 'b5':
            for ( var w1=0, len1 = frm1.length; w1<len1; w1++ )
            {
                for ( var w2=0, len2 = frm2.length; w2<len2; w2++ )
                {
                    if (frm1[w1] != frm2[w2])
                    {
                        kumi[0] = frm1[w1];
                        kumi[1] = frm2[w2];
                        kumi.sort();
                        ten_count[ kumi[0] + "-" + kumi[1] ] = 1;
                    }
                }
            }
            break;
        case 'b6':
            for ( var w1=0, len1 = frm1.length; w1<len1; w1++ )
            {
                for ( var w2=0, len2 = frm2.length; w2<len2; w2++ )
                {
                    if (frm1[w1] != frm2[w2])
                    {
                        kumi[0] = frm1[w1];
                        kumi[1] = frm2[w2];
                        ten_count[ kumi[0] + "-" + kumi[1] ] = 1;
                    }
                }
            }
            break;
        case 'b7':
            for ( var w1=0, len1 = frm1.length; w1<len1; w1++ )
            {
                for ( var w2=0, len2 = frm2.length; w2<len2; w2++ )
                {
                    for ( var w3=0, len3 = frm3.length; w3<len3; w3++ )
                    {
                        if (frm1[w1] != frm2[w2] && frm1[w1] != frm3[w3] && frm2[w2] != frm3[w3])
                        {
                            kumi[0] = frm1[w1];
                            kumi[1] = frm2[w2];
                            kumi[2] = frm3[w3];
                            kumi.sort();
                            ten_count[ kumi[0] + "-" + kumi[1] + "-" + kumi[2] ] = 1;
                        }
                    }
                }
            }
            break;
        case 'b8':
            for ( var w1=0, len1 = frm1.length; w1<len1; w1++ )
            {
                for ( var w2=0, len2 = frm2.length; w2<len2; w2++ )
                {
                    for ( var w3=0, len3 = frm3.length; w3<len3; w3++ )
                    {
                        if (frm1[w1] != frm2[w2] && frm1[w1] != frm3[w3] && frm2[w2] != frm3[w3])
                        {
                            kumi[0] = frm1[w1];
                            kumi[1] = frm2[w2];
                            kumi[2] = frm3[w3];
                            ten_count[ kumi[0] + "-" + kumi[1] + "-" + kumi[2] ] = 1;
                        }
                    }
                }
            }
            break;
        }
        console.log(Object.keys(ten_count).length);
        return Object.keys(ten_count).length;

        break;
        
    //ボックス点数計算
    case 'c2':
        var frm1 = []; //[];
        var i=0;
        
        i=0;
        $("[id^='chk_frm1']").each(function()
    	{
    		var chkbox = $(this);
    		if ( chkbox.prop("checked") == true )
    		{
                frm1[i++]=$(this).val();
    		}
        });

        var ten_count = 0;
        switch(_kind)
        {
        case 'b4':
        case 'b5':
            if (frm1.length>=2)
            {
                ten_count = frm1.length * (frm1.length-1)/2;
