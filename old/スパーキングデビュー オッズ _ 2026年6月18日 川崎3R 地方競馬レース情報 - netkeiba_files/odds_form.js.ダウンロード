        }
        console.log(ten_count);
        return ten_count;
        break;

    //流し点数計算
    default:
        var jiku1 = []; //[];
        var jiku2 = []; //[];
        var frm1 = []; //[];
        var i=0;

        $("[id^='chk_frm1']").each(function()
