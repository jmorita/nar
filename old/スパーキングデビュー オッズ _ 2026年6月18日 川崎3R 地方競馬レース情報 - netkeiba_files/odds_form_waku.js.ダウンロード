function chkBoxAllClrWaku(chkid1)
{
    $("[id^='"+chkid1+"']").each(function()
	{
		var chkbox1 = $(this);
		chkbox1.prop("checked", false);	//チェックボックスをOFFにする
	});
}

//===========================================================
// 「MY印の馬を選択」を押したときに実行される処理
//
// MY印が設定されている馬に対応するchkboxをONにする
// ただし、--と消 の馬にはOFFを設定
//
// in: selbtn       = 選択boxのid
//===========================================================
function setMySirusiWaku(selbtn)
{
    console.log('setMySirusi');

    $("[id^='"+selbtn+"']").each(function()
	{
		var chkbox = $(this);
		chkbox.prop("checked", false);
	});

	// ユーザーのMY印
    $("[id^='mymark_']").each(function()
	{ // ドキュメント内のMY印の選択ボックスの数だけループ

		var select 		= $(this);
		var tmp_seq 	= select[0].id;			//seq
		var mark 	= $(this).attr('value');		//umaban,mark
		var seq 	= tmp_seq.split('_');

		var chkbox1 = $('#'+ selbtn + seq[2]);
		var count = String(chkbox1.val());	//チェックボックスの枠番
		var count_val = count.split('_');

		if ( $('#rd_jiku_'+seq[2]).prop("checked") != true && $('#'+ selbtn + seq[2]).prop("checked") == false || count_val[1]>1)
		{// 該当馬が軸馬として指定されていないとき

			if ( $('#'+ selbtn + seq[2]).prop("checked") == false )
			{
				if(mark != 0 && mark != 99 && mark != undefined)
				{// -- でも 消 でもない => チェックつける
					$('#'+ selbtn + seq[2]).prop("checked", true);
				}
				else
				{// チェック消す
					$('#'+ selbtn + seq[2]).prop("checked", false);
				}
			}
		}
	});
}

