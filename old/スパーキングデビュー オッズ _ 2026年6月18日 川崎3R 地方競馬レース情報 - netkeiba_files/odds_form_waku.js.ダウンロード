//===========================================================
// MY印の初期値をセットする
// in: _cart  ...cart_get_itemlist()の戻り(item_id)
//===========================================================
function init_select_mark_waku( _cart )
{
    console.log('init_select_mark');

    var ary_mark = new Array();

	// 該当レースで選択されたMY印を取得
    for(var item_id in _cart)
	{
		var tmp = _cart[item_id]['_cd'];
		var mark = tmp.split('_');
		if ('1' in mark)
		{
			ary_mark[ item_id ] = mark[1];	//重み印モードのとき
		}
		else
		{
			ary_mark[ item_id ] = 100;		//チェックモードのとき
		}
		console.log('item_id='+item_id+' client_data='+ary_mark[ item_id ]);
    }

	// ユーザーのMY印をセット
    $("[id^='mymark_']").each(function()
	{ // ドキュメント内のMY印の選択ボックスの数だけループ

		var box 		= $(this);
		var tmp_seq 	= box[0].id;			//seq
		var seq 	= tmp_seq.split('_');
		var mark_data 	= ary_mark[seq[1]];
		if (!mark_data || mark_data == 0) mark_data = '00';

		$(this).parent().removeClass('MarkIcon Mark00');
		$(this).parent().addClass('MarkIcon Mark'+mark_data);
		$(this).attr('value', mark_data);
    });

}

//------------------------------------------------------------
// 指定したidのチェックボックスを全設定・全解除する
//------------------------------------------------------------
function chkBoxAllsetWaku(chkid1)
{
    $("[id^='"+chkid1+"']").each(function()
	{
		var chkbox1 = $(this);
		var count = chkbox1.val();	//チェックボックスの枠番
		var count_val = count.split('_');
		var rdchk = $(':radio[name="jiku"]:checked').val();		//ラジオボタンの枠番

		if (rdchk != undefined)	//軸指定
		{//軸あり
			var rdchk_val = rdchk.split('_');
			if ( rdchk_val[0] != count_val[0] && count_val[1] > 0)
			{
				chkbox1.prop("checked", true);	//軸と異なる相手枠はチェック
			}
			else
			{
				if ( count_val[1] > 1 )
				{
					chkbox1.prop("checked", true);	//同枠でも１頭以上相手がいる場合はチェック
				}
				//else
				//軸と同枠の相手はチェックしない
			}
		}
		else
		{//軸なし
            
            if ( count_val[1] > 0)
            {//枠が有効のとき
    			chkbox1.prop("checked", true);	//チェックボックスをONにする
    	    }
		}
	});
}

//------------------------------------------------------------
// チェックボックス全てクリアする
