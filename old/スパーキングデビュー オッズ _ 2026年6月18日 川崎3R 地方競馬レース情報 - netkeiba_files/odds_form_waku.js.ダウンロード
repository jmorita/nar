    var ary_kind = {b3:(TEXT_DICT?TEXT_DICT['WAKUREN']:"枠連")+" ",b9:(TEXT_DICT?TEXT_DICT['WAKUREN']:"枠単")+" "};
    console.log(ary_kind);
    i=0;
    $("[id^='chk_frm1']").each(function()
	{
		var chkbox = $(this);
		if ( chkbox.prop("checked") == true )
		{
            frm1[i++]=$(this).val();
		}
    });
    i=0;
    $("[id^='chk_frm2']").each(function()
	{
		var chkbox = $(this);
		if ( chkbox.prop("checked") == true )
		{
            frm2[i++]=$(this).val();
		}
    });
    $("[id^='rd_jiku_']").each(function()
	{
		var chkbox = $(this);
		if ( chkbox.prop("checked") == true )
		{
            jiku1[0]=$(this).val();
		}
    });
    $("[id^='chk_multi']").each(function()
	{
		var chkbox = $(this);
		if ( chkbox.prop("checked") == true )
		{
            mult_flg = 1;
		}
    });


    dsp_kumi = '';
    dsp_kaime = '';

    switch(_kind + _type)
    {
    //フォーメーション点数計算
    case 'b3c1':
    case 'b9c1':
        // dsp_kumi += ary_kind[_kind]+"フォーメーション";
        dsp_kumi += ary_kind[_kind] + (TEXT_DICT?TEXT_DICT['FORMATION']:"フォーメーション");
        dsp_kaime += '<tr><th><div>'+$("#conf_frm1")[0].innerHTML+'</div></th><td class="Num">' + make_rectangle_number_waku(frm1) + "</td></tr>";
        dsp_kaime += '<tr><th><div>'+$("#conf_frm2")[0].innerHTML+'</div></th><td class="Num">' + make_rectangle_number_waku(frm2) + "</td></tr>";
        break;

    case 'b3c2':
    case 'b9c2':
        // dsp_kumi += ary_kind[_kind]+"ボックス";
        dsp_kumi += ary_kind[_kind] + (TEXT_DICT?TEXT_DICT['BOX']:"ボックス");
        dsp_kaime += '<tr class="Box"><th><div>'+$("#conf_frm1")[0].innerHTML + '</div></th><td class="Num">' + make_rectangle_number_waku(frm1) + "</td></tr>";
        break;
        
    case 'b3c3':
    case 'b9c3':
    case 'b9c4':
        // dsp_kumi += ary_kind[_kind]+"ながし";
        dsp_kumi += ary_kind[_kind] + (TEXT_DICT?TEXT_DICT['NAGASHI']:"ながし");
        dsp_kaime += '<tr><th><div>'+$("#conf_jiku1")[0].innerHTML + '</div></th><td class="Num">' + make_rectangle_number_waku(jiku1) + "</td></tr>";
        dsp_kaime += '<tr><th><div>'+$("#conf_frm1")[0].innerHTML + '</div></th><td class="Num">' + make_rectangle_number_waku(frm1) + "</td></tr>";
        if(mult_flg)
        {
            dsp_kaime += '<tr><th><div>type</div></th><td class="Num"><div>マルチ</div></td></tr>';
        }
        break;
    }
    
    $("#select_type")[0].innerHTML = dsp_kumi;
    $("#select_kumiawase").html("<table>"+ dsp_kaime + "</table>");
}


