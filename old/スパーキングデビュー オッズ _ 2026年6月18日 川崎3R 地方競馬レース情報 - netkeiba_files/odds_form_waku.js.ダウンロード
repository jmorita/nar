//
// 数字を□囲みに書き換える
//
function make_rectangle_number_waku(ary_number)
{
    var html_tmp="";
    var wakuban="";
    for (var i = 0; i < ary_number.length; i ++) {
        wakuban = ary_number[i].substring(0,1);
        // html_tmp += '<span class="UmaBan">'+wakuban+'</span>';
        if (i>0) {
            html_tmp += '<span class="BackSlash">/</span>' + wakuban;
        } else {
            html_tmp += wakuban;
        }
    }
    return html_tmp;
}



