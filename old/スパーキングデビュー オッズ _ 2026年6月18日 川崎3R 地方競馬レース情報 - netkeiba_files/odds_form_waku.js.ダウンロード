function chkSameAite_Jiku_Waku(_seq)
{
	var chkbox1 = $('#chk_frm1_' + _seq);
	var count = String(chkbox1.val());	//チェックボックスの枠番
	var count_val = count.split('_');
	if ( $('#rd_jiku_' + _seq).prop("checked") == true && count_val[1]<2)
	{//同枠を軸にチェックして且つ同枠に２頭未満のときはチェック解除
        
		$('#chk_frm1_' + _seq).prop("checked", false);
	}
	else if (count_val[1]<1)
	{
		$('#chk_frm1_' + _seq).prop("checked", false);
    }
}

function update_cart_checkbox( _group, _item_id, _item_value, _client_data, _checked )
{
