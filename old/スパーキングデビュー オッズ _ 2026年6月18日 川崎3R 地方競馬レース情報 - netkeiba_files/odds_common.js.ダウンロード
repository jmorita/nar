//------------------------------------------------------------
// 買い目点数のカウント・表示
//------------------------------------------------------------
function view_check_count()
{
    var cnt = 0;
    $("[id^='check_" + _baken_kind + "']").each(function()
	{
		var chkbox = $(this);
		if ( chkbox.prop("checked") == true )
		{
			cnt++;
		}
    });
    console.log('view_check_count _cnt='+cnt);
    $('#odds_select').text( cnt);




    var limit = '50';
    var cookie = document.cookie.split(';');
    for(var i = 0; i < cookie.length; i++){
        var item = cookie[i].split('=');
        //投票モード確認
        if(item[0].trim() === 'bet_mode' && item[1].trim() === 'spat4'){
            limit = '120';
        }
    }
    var err_text = '件数オーバー(1度の投票は'+limit+'件まで)';

    //51件以上の買い目が選択されている場合はアラートメッセージ
    if(cnt==0)
    {
//        $('#bet_window').css("display", "none");
    }
    else if(cnt>limit)
    {
        $('#bet_window').css("display", "block");
        $('#caution_50bet').css("display", "block");
        $('#caution_50bet > font').text(err_text);
    }
    else
    { 
        $('#bet_window').css("display", "block");
        $('#caution_50bet').css("display", "none");
		$('#bet_window').show();
    }
}

function update_cart_checkbox( _group, _item_id, _item_value, _client_data, _checked )
{
    console.log('update_cart_checkbox');

    if(true == _checked){
	cart_add_item( _group, _item_id, _item_value, '', _client_data );
    }else{
	cart_remove_item( _group, _item_id );
    }
}

