//
// 数字を□囲みに書き換える
//
function rectangle_number()
{
    $("[id^='rectangle']").each(function() {
			var number 	= $(this);
			var tmp = number[0].innerHTML;
			var mark = tmp.split(' , ');

			var html_tmp = '';

			for (var i = 0; i < mark.length; i ++) {
					html_tmp += '<span class="UmaBan">'+mark[i]+'</span>';
			}
	    number[0].innerHTML = html_tmp;
    });
}

