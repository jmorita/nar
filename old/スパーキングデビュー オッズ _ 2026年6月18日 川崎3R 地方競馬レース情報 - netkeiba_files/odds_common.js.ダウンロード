//------------------------------------------------------------
// 指定したidのチェックボックスを全設定・全解除
//------------------------------------------------------------
function chkBoxAll(checked)
{
    var i=0;
    var item_ids = new Array();

    $("[id^='check_b_']").each(function(){
        var chkbox1 = $(this);
        item_ids[i++] = chkbox1[0].name;
        chkbox1.prop("checked", checked);

        if (checked == true)
        {
            $(this).parent().parent().addClass('Selected');
        }
        else
        {
            $(this).parent().parent().removeClass('Selected');
        }
    });
    update_cart_checkbox( _cart_group_bet, item_ids, 1, '', checked);
    view_check_count();
}

